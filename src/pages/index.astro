---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import EntryList from '../components/EntryList.astro';
import { getTils, getPosts } from '../lib/content';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const tils = (await getTils()).slice(0, 5);
const posts = (await getPosts()).slice(0, 3);

// The home thesis, hand-set to tumble down the page like a specimen spread.
const hero = [
  { text: 'I build', size: 'xl', weight: 640, rot: -2 },
  { text: 'things,', size: 'l', weight: 400, shift: '7rem', rot: 1.5 },
  { text: 'break them,', size: 'xl', weight: 360, italic: true, shift: '1.5rem', rot: -1 },
  { text: 'and write', size: 'm', weight: 560, shift: '10rem', rot: 2 },
  { text: 'down why.', size: 'xl', weight: 760, shift: '3rem', rot: -1.5 },
] as const;
---

<Base title={SITE_TITLE} description={SITE_DESCRIPTION} type="website">
  <div class="stack">
    <PageHeader eyebrow="The running notebook of Shreyash Rai" lines={hero} dense>
      <p class="masthead__deck">
        I'm a Data Science &amp; AI undergrad at IIIT Naya Raipur. This is where I
        keep a running log of things I learn (<a href="/til">TILs</a>) and write
        up the <a href="/projects">projects</a> I make.
      </p>
    </PageHeader>

    <div class="home-split">
      <section class="home-split__til">
        <div class="section-head">
          <h2 class="display display--section">Today I learned</h2>
          <a class="annotation link-quiet" href="/til">all TILs &rarr;</a>
        </div>
        <EntryList items={tils} />
      </section>

      <section class="home-split__writing">
        <div class="section-head">
          <h2 class="display display--section">Writing</h2>
          <a class="annotation link-quiet" href="/blog">all posts &rarr;</a>
        </div>
        <EntryList items={posts} showDescription />
        <p class="annotation home-split__rss">
          <a class="link-quiet" href="/rss.xml">Follow along via RSS &rarr;</a>
        </p>
      </section>
    </div>
  </div>
</Base>
