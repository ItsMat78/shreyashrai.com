---
import Base from './Base.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TagList from '../components/TagList.astro';
import { SITE_TITLE } from '../consts';

// Shared shell for a single TIL or post: kicker, display title, meta row,
// rendered body. `eyebrow` names which section it belongs to.
interface Props {
  title: string;
  date: Date;
  tags: string[];
  description?: string;
  eyebrow?: string;
}

const { title, date, tags, description, eyebrow } = Astro.props;
---

<Base title={`${title} — ${SITE_TITLE}`} description={description} type="article">
  <article>
    <header class="article__header">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1 class="display display--title">{title}</h1>
      <div class="article__meta">
        <FormattedDate date={date} format="long" />
        <TagList tags={tags} />
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</Base>
