---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import FrameField from '../../components/FrameField.astro';
import Toc from '../../components/Toc.astro';
import Backlinks from '../../components/Backlinks.astro';
import Comments from '../../components/Comments.astro';
import { getProjectEntries, getBacklinks, getRelatedProjects } from '../../lib/content';

// One page per project. Drafts never get a route (draft filter lives in the
// content layer).
export async function getStaticPaths() {
  const entries = await getProjectEntries();
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const backlinks = await getBacklinks(entry.id);
const related = await getRelatedProjects(entry.id, entry.data.tech);
---

<Base
  title={entry.data.title}
  description={entry.data.blurb}
  type="article"
  ogImage={`/og/projects/${entry.id}.png`}
>
  <article>
    <header class="article__header">
      <FrameField />
      {entry.data.headerArt && (
        <img class="header-art" src={entry.data.headerArt} alt="" decoding="async" />
      )}
      <p class="eyebrow">About the project</p>
      <h1 class="display display--title">{entry.data.title}</h1>
      {entry.data.outcome && (
        <p class="project__outcome project__outcome--lead">{entry.data.outcome}</p>
      )}
      
      {entry.data.tech.length > 0 && (
        <ul class="project__tech" aria-label="Tech stack">
          {entry.data.tech.map((t) => (
            <li>{t}</li>
          ))}
        </ul>
      )}
      <div class="article__meta annotation">
        {entry.data.live && (
          <a class="link-quiet" href={entry.data.live}>
            Live Demo <span class="project__arrow"><svg viewBox="0 0 12 12" width="0.8em" height="0.8em" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 10 10 2M4 2h6v6"/></svg></span>
          </a>
        )}
        {entry.data.source && (
          <a class="link-quiet" href={entry.data.source}>
            REPOSITORY <span class="project__arrow"><svg viewBox="0 0 12 12" width="0.8em" height="0.8em" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 10 10 2M4 2h6v6"/></svg></span>
          </a>
        )}
      </div>
    </header>
    <div class="article__body">
      <Toc headings={headings} />
      <div class="prose" data-pagefind-body>
        <Content />
      </div>
    </div>
    <p class="article__end" aria-hidden="true">&#10086;</p>
    <div class="article__trail">
      <Backlinks links={backlinks} />
      {related.length > 0 && (
        <nav class="related" aria-label="More projects">
          <p class="related__title eyebrow">Other reads</p>
          <ul class="related__list">
            {related.map((item) => (
              <li class="related__item">
                <a class="related__link" href={`/projects/${item.id}`}>
                  {item.data.title}
                </a>
                <span class="annotation related__kind">Project</span>
              </li>
            ))}
          </ul>
        </nav>
      )}
    </div>
    <nav class="article-nav" aria-label="More in Projects">
      <a class="article-nav__back" href="/projects">&larr; All Projects</a>
    </nav>
    <Comments />
  </article>
</Base>
