---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import { SITE_TITLE } from '../consts';

const heading = [
  { text: 'Nothing', size: 'l', weight: 400, rot: -1.5 },
  { text: 'here,', size: 'xl', weight: 700, shift: '3rem', rot: 1.5 },
  { text: 'sorry.', size: 'l', weight: 360, italic: true, shift: '8rem', rot: -2 },
] as const;
---

<Base title={`Not found — ${SITE_TITLE}`} description="That page doesn't exist.">
  <PageHeader eyebrow="Error 404" lines={heading}>
    <p class="masthead__deck">
      That page doesn't exist. Try the <a href="/til">TILs</a>, the
      <a href="/blog">blog</a>, or head <a href="/">home &rarr;</a>
    </p>
  </PageHeader>
</Base>
