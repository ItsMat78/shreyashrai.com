---
import { render } from 'astro:content';
import Article from '../../layouts/Article.astro';
import {
  getTilEntries,
  normalizeTags,
  getRelated,
  getBacklinks,
  getSeries,
} from '../../lib/content';

// Paths come from the same draft-filtered getter used everywhere, so a draft
// never gets its own page in a build.
export async function getStaticPaths() {
  const entries = await getTilEntries();
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const tags = normalizeTags(entry.data.tags);

// The connected-notebook trail: tag-related entries, reverse [[wikilink]]
// mentions, and any series this note is part of.
const [related, backlinks, seriesParts] = await Promise.all([
  getRelated(entry.id, tags),
  getBacklinks(entry.id),
  entry.data.series ? getSeries(entry.data.series) : Promise.resolve([]),
]);
---

<Article
  id={entry.id}
  collection="til"
  title={entry.data.title}
  date={entry.data.date}
  tags={tags}
  eyebrow="Today I learned"
  headings={headings}
  series={entry.data.series}
  seriesParts={seriesParts}
  related={related}
  backlinks={backlinks}
  comments
>
  <Content />
</Article>
