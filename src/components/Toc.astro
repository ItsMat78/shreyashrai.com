---
// Table of contents for an article, built from the headings Astro extracts
// at render time. Shows h2/h3 only; hidden entirely when there's nothing
// worth listing. Sits inline on small screens and becomes a sticky right
// rail on wide ones (see .toc in global.css).
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
// h2/h3 only — the page's one true h1 is the article title, so body
// sections start at ##. Indentation is relative to the shallowest level
// actually used (an h3-only file still reads flush).
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
const minDepth = items.length > 0 ? Math.min(...items.map((h) => h.depth)) : 2;
---

{
  items.length >= 2 && (
    <nav class="toc" aria-label="Contents">
      <details class="disclosure" open>
        <summary class="disclosure__summary">
          <span class="eyebrow">Contents</span>
          <span class="disclosure__chevron" aria-hidden="true" />
        </summary>
        <ol>
          {items.map((h) => (
            <li data-indent={h.depth - minDepth}>
              <a class="link-quiet" href={`#${h.slug}`}>
                {h.text}
              </a>
            </li>
          ))}
        </ol>
      </details>
      <script is:inline>
        (function () {
          var d = document.currentScript.previousElementSibling;
          if (d && !window.matchMedia('(min-width: 72rem)').matches) d.open = false;
        })();
      </script>
    </nav>
  )
}

<script>
  // Scroll-spy: highlight the contents entry for the section being read.
  // The active heading is the last one whose top has scrolled above a line
  // just below the sticky header — robust to fast scrolls and heading gaps.
  const toc = document.querySelector('.toc');
  if (toc) {
    const links = new Map<string, HTMLAnchorElement>();
    toc.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
      links.set(decodeURIComponent(a.hash.slice(1)), a);
    });
    const headings = [...links.keys()]
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);

    if (headings.length) {
      const OFFSET = 96; // clears the sticky header
      let current = '';
      const setActive = (id: string) => {
        if (id === current) return;
        current = id;
        links.forEach((a, key) => {
          const on = key === id;
          a.classList.toggle('is-active', on);
          if (on) a.setAttribute('aria-current', 'true');
          else a.removeAttribute('aria-current');
        });
      };

      const update = () => {
        let activeId = headings[0].id;
        for (const h of headings) {
          if (h.getBoundingClientRect().top <= OFFSET) activeId = h.id;
          else break;
        }
        setActive(activeId);
      };

      update();
      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          update();
          ticking = false;
        });
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
    }
  }
</script>
