---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import { getAllTags } from '../lib/content';

const tags = (await getAllTags()).slice(0, 16);

// Full-text search over every TIL, post, and project. The index is built by
// Pagefind AFTER `astro build` (see package.json) and served from /pagefind,
// so search works in `astro preview` and production — not in `astro dev`.
const heading = [
  { text: 'Find', size: 'xl', weight: 640, rot: -1.5 },
  { text: 'anything', size: 'l', weight: 380, italic: true, shift: '4rem', rot: 1.5, lift: '-1.6rem' },
] as const;
---

<Base title="Search" description="Search every TIL, post, and project on the site.">
  <PageHeader eyebrow="The whole archive" lines={heading}>
    <p class="masthead__deck">Search across every note, essay, and writeup.</p>
  </PageHeader>

  <section>
    <div class="section-head">
      <h2 class="display display--section">Browse by tag</h2>
      <a class="annotation link-quiet" href="/tags">all tags &rarr;</a>
    </div>
    <div class="tag-row">
      {tags.map(({ tag }) => (
        <a class="tag" href={`/tags/${tag}`}>{tag}</a>
      ))}
    </div>
  </section>

  {/* Pagefind is loaded + mounted from the Base client module (initSearch),
      so it survives View Transitions — reaching /search via an in-site link
      (e.g. the header icon on mobile) mounts the UI just the same. */}
  <div id="search" class="search-ui"></div>
  <noscript>
    <p class="annotation">Search needs JavaScript. Browse the <a href="/notes">notes</a> or <a href="/tags">tags</a> instead.</p>
  </noscript>
</Base>
