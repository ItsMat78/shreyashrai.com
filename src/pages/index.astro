---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import EntryList from '../components/EntryList.astro';
import Newsletter from '../components/Newsletter.astro';
import { getTils, getPosts, getFeatured } from '../lib/content';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const tils = (await getTils()).slice(0, 5);
const posts = (await getPosts()).slice(0, 3);
// The standout entry (frontmatter `featured: true`), if any — newest wins.
const featured = (await getFeatured())[0];

// The home thesis: two breaths, roman then italic — learning in public.
const hero = [
  { text: 'Learning', size: 'xl', weight: 680, rot: -1.5 },
  { text: 'out loud.', size: 'xl', weight: 400, italic: true, shift: '5.8rem', rot: 1, lift:'-1.5rem' },
] as const;
---

<Base title={SITE_TITLE} description={SITE_DESCRIPTION} type="website">
  <div class="stack">
    <PageHeader eyebrow="The running notebook for" lines={hero}>
      <p class="masthead__deck">
        I'm a Data Science &amp; AI undergrad at IIIT Naya Raipur. This is where I
        keep a running log of things I learn (<a href="/til">TILs</a>) and document the <a href="/projects">projects</a> I curate.
      </p>
    </PageHeader>

    {
      featured && (
        <a class="featured" href={featured.url}>
          <span class="featured__label eyebrow">Featured · {featured.collection}</span>
          <span class="featured__title">{featured.title}</span>
          {featured.description && (
            <span class="featured__desc">{featured.description}</span>
          )}
          <span class="featured__cue annotation">Read &rarr;</span>
        </a>
      )
    }

    <div class="home-split">
      <section class="home-split__til">
        <div class="section-head">
          <h2 class="display display--section">Today I learned</h2>
          <a class="annotation link-quiet" href="/til">all TILs &rarr;</a>
        </div>
        <EntryList items={tils} />
      </section>

      <section class="home-split__writing">
        <div class="section-head">
          <h2 class="display display--section">Writing</h2>
          <a class="annotation link-quiet" href="/blog">all posts &rarr;</a>
        </div>
        <EntryList items={posts} showDescription />
        <p class="annotation home-split__rss">
          <a class="link-quiet" href="/rss.xml">Follow along via RSS &rarr;</a>
        </p>
      </section>
    </div>

    <Newsletter />
  </div>
</Base>
