---
// The one dated-list component, shared by the home page, /til, /blog, and
// /tags/[tag]. Vertical stack: date + kind on one line, then title, then
// description, then tags grouped at the bottom.
import type { EntryItem } from '../lib/content';
import FormattedDate from './FormattedDate.astro';
import TagList from './TagList.astro';
import { inlineMarkdown } from '../lib/markdown';

interface Props {
  items: EntryItem[];
  // Show the blog `description` under the title (used on /blog and home posts).
  showDescription?: boolean;
  // Show a small "til" / "blog" marker (used on mixed lists like tag pages).
  showKind?: boolean;
}

const { items, showDescription = false, showKind = false } = Astro.props;

// Friendly kind markers so mixed lists read as "TIL / Writing", not "til / blog".
const KIND_LABEL: Record<EntryItem['collection'], string> = {
  til: 'TIL',
  blog: 'Writing',
  links: 'Link',
  quotes: 'Quote',
};
---

<ul class="entry-list">
  {
    items.map((item) => (
      <li class="entry">
        <div class="entry__meta">
          <FormattedDate date={item.date} />
          {showKind && <span class="annotation entry__kind">{KIND_LABEL[item.collection]}</span>}
        </div>
        <a class="entry__title" href={item.url}>
          {item.title}
        </a>
        {showDescription && item.description && (
          <p class="entry__desc" set:html={inlineMarkdown(item.description)} />
        )}
        <TagList tags={item.tags} />
      </li>
    ))
  }
</ul>
