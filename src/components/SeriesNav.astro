---
// A multi-part series index, shown above an article that belongs to one. Lists
// every part in order with the current one marked, so a reader can move through
// a sequence (e.g. a course log) without hunting the archive.
import type { EntryItem } from '../lib/content';
import { seriesSlug } from '../lib/content';

interface Props {
  name: string;
  parts: (EntryItem & { part?: number })[];
  currentId: string;
  // 'rail' (default) sits in the article's contents rail — collapsed on phones.
  // 'end' is a mobile-only copy dropped at the foot of the article, kept EXPANDED
  // so a reader can pick the next part after finishing (hidden on the wide rail).
  variant?: 'rail' | 'end';
}

const { name, parts, currentId, variant = 'rail' } = Astro.props;

// Position of the piece being read, for the end-card's "Part X of N" line.
const currentIndex = parts.findIndex((p) => p.id === currentId);
---

{
  parts.length > 0 && (
    <aside
      class:list={['series', variant === 'end' && 'series--end']}
      aria-label={`Series: ${name}`}
      data-pagefind-ignore
    >
      <details class="disclosure" open>
        <summary class="disclosure__summary">
          <span class="eyebrow">
            Series ·{' '}
            <a class="series__link" href={`/series/${seriesSlug(name)}`}>{name}</a>
          </span>
          <span class="disclosure__chevron" aria-hidden="true" />
        </summary>
        {variant === 'end' && currentIndex >= 0 && (
          <p class="series__progress">
            Part {currentIndex + 1} of {parts.length}
          </p>
        )}
        <ol class="series__list">
          {parts.map((p, i) => {
            const current = p.id === currentId;
            return (
              <li class:list={['series__item', current && 'series__item--current']}>
                <span class="series__num tabular" aria-hidden="true">
                  {String(p.part ?? i + 1).padStart(2, '0')}
                </span>
                {current ? (
                  <span aria-current="true">{p.title}</span>
                ) : (
                  <a class="link-quiet" href={p.url}>
                    {p.title}
                  </a>
                )}
              </li>
            );
          })}
        </ol>
      </details>
      {variant === 'rail' && (
        <script is:inline>
          (function () {
            var d = document.currentScript.previousElementSibling;
            if (d && !window.matchMedia('(min-width: 72rem)').matches) d.open = false;
          })();
        </script>
      )}
    </aside>
  )
}
