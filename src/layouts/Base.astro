---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  // Absolute site path to a share card (e.g. /og/blog/foo.png). Defaults to
  // the site card in BaseHead when omitted.
  ogImage?: string;
}

const { title, description, type, ogImage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} type={type} ogImage={ogImage} />
    <base target="_blank" />
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const blocks = document.querySelectorAll('pre[data-language="mermaid"]');
        if (!blocks.length) return;
        blocks.forEach((pre) => {
          const div = document.createElement('div');
          div.className = 'mermaid';
          div.textContent = pre.textContent;
          pre.replaceWith(div);
        });
        const dark = document.documentElement.getAttribute('data-theme') === 'dark';
        import('mermaid').then((m) => {
          m.default.initialize({ startOnLoad: false, theme: dark ? 'dark' : 'default' });
          m.default.run();
        });
      });
    </script>
  </head>
  <body>
    <div class="site">
      <Header />
      <main>
        <div class="container">
          <slot />
        </div>
      </main>
      <Footer />
    </div>

    <script>
      // All client behaviour lives here in ONE module (executed once) so it
      // survives Astro View Transitions: listeners are bound to `document` and
      // to the transition lifecycle rather than to per-page elements.

      const COPY_ICON =
        '<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="12" height="12" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
      const CHECK_ICON =
        '<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12.5 9.5 18 20 6.5"/></svg>';

      // Copy-to-clipboard on every code block. Idempotent: skips any <pre> that
      // is already wrapped, so it can safely re-run after each navigation.
      function initCopyButtons() {
        for (const pre of document.querySelectorAll<HTMLElement>('.prose pre')) {
          if (pre.closest('.code-wrap')) continue;
          const wrap = document.createElement('div');
          wrap.className = 'code-wrap';
          pre.parentNode?.insertBefore(wrap, pre);
          wrap.appendChild(pre);

          const btn = document.createElement('button');
          btn.className = 'code-copy';
          btn.type = 'button';
          btn.setAttribute('aria-label', 'Copy code');
          btn.innerHTML = COPY_ICON;
          btn.addEventListener('click', async () => {
            const code = pre.querySelector('code') as HTMLElement | null;
            const text = code?.innerText ?? pre.innerText;
            try {
              await navigator.clipboard.writeText(text);
              btn.innerHTML = CHECK_ICON;
              btn.classList.add('code-copy--done');
              setTimeout(() => {
                btn.innerHTML = COPY_ICON;
                btn.classList.remove('code-copy--done');
              }, 1800);
            } catch {
              /* clipboard unavailable (http, old browser): do nothing */
            }
          });
          wrap.appendChild(btn);
        }
      }

      // Loading skeleton: wrap each content image/video in a .media-frame that
      // shows the tetromino cube until the file loads (or errors), then fades the
      // media in. Idempotent (skips already-wrapped) so it re-runs after every
      // navigation. Only figure-row thumbnails are left alone — they're too
      // small for the cube and already sit on their own framed plate.
      const TETROMINO =
        '<span class="tetrominos" aria-hidden="true">' +
        '<span class="tetromino box1"></span>' +
        '<span class="tetromino box2"></span>' +
        '<span class="tetromino box3"></span>' +
        '<span class="tetromino box4"></span>' +
        '</span>';

      function initMediaSkeletons() {
        const media = document.querySelectorAll<HTMLImageElement | HTMLVideoElement>(
          '.prose img, .prose video',
        );
        for (const el of media) {
          if (el.closest('.media-frame') || el.closest('.figure-row')) continue;

          const frame = document.createElement('span');
          frame.className = 'media-frame';
          // A float belongs on the wrapper so text still wraps past a loading
          // img-left / img-right; the media itself then fills the wrapper.
          for (const side of ['img-left', 'img-right']) {
            if (el.classList.contains(side)) {
              frame.classList.add(side);
              el.classList.remove(side);
            }
          }

          el.parentNode?.insertBefore(frame, el);
          frame.appendChild(el);
          frame.insertAdjacentHTML('afterbegin', TETROMINO);

          const done = () => frame.classList.add('is-loaded');
          const img = el instanceof HTMLImageElement ? el : null;
          const vid = el instanceof HTMLVideoElement ? el : null;
          if (img && img.complete && img.naturalWidth > 0) {
            done();
          } else if (vid && vid.readyState >= 2) {
            done();
          } else {
            el.addEventListener('load', done, { once: true });
            el.addEventListener('loadeddata', done, { once: true });
            el.addEventListener('error', done, { once: true });
          }
        }
      }

      // Theme: the inline head script sets [data-theme] before first paint; this
      // re-applies it the instant a new page is swapped in so it never flashes.
      function applyTheme() {
        try {
          const t = localStorage.getItem('theme');
          document.documentElement.dataset.theme =
            t === 'dark' || t === 'light' ? t : 'light';
        } catch {
          /* localStorage blocked: leave whatever is already set */
        }
      }

      // Keep the toggle's icon/label in sync with the current theme.
      function syncToggle() {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        const icon = btn.querySelector('.theme-toggle__icon');
        const dark = document.documentElement.dataset.theme === 'dark';
        if (icon) icon.textContent = dark ? '☀' : '☾';
        btn.setAttribute('aria-label', dark ? 'Switch to light theme' : 'Switch to dark theme');
        btn.setAttribute('aria-pressed', dark ? 'true' : 'false');
      }

      // Delegated click: one listener on document survives every page swap.
      document.addEventListener('click', (e) => {
        const target = e.target;
        const btn = target instanceof Element ? target.closest('#theme-toggle') : null;
        if (!btn) return;
        const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        try {
          localStorage.setItem('theme', next);
        } catch {
          /* ignore */
        }
        syncToggle();
      });

      // Rail dropdowns (TOC + series): collapsed on phones, forced open on the
      // wide sticky rail. The per-component inline script handles first paint;
      // this keeps them in sync across navigations and viewport changes.
      const wideRail = window.matchMedia('(min-width: 72rem)');
      function syncRail() {
        for (const d of document.querySelectorAll<HTMLDetailsElement>('.rail details')) {
          d.open = wideRail.matches;
        }
      }
      wideRail.addEventListener('change', syncRail);

      // Contents scroll-spy: highlight the TOC entry for the section being read.
      // State is rebuilt on every navigation (initTocSpy) while the scroll/resize
      // listeners are bound ONCE below and always read the latest state — so it
      // keeps working after client-side page swaps, not just the first load.
      let spyLinks = new Map<string, HTMLAnchorElement>();
      let spyHeadings: HTMLElement[] = [];
      let spyCurrent = '';
      const SPY_OFFSET = 96; // clears the sticky header

      function initTocSpy() {
        spyLinks = new Map();
        spyHeadings = [];
        spyCurrent = '';
        const toc = document.querySelector('.toc');
        if (!toc) return;
        toc.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
          spyLinks.set(decodeURIComponent(a.hash.slice(1)), a);
        });
        spyHeadings = [...spyLinks.keys()]
          .map((id) => document.getElementById(id))
          .filter((el): el is HTMLElement => el !== null);
        updateTocSpy();
      }

      function updateTocSpy() {
        if (!spyHeadings.length) return;
        // The active heading is the last one whose top has scrolled above the
        // line just under the sticky header — robust to fast scrolls and gaps.
        let activeId = spyHeadings[0].id;
        for (const h of spyHeadings) {
          if (h.getBoundingClientRect().top <= SPY_OFFSET) activeId = h.id;
          else break;
        }
        if (activeId === spyCurrent) return;
        spyCurrent = activeId;
        spyLinks.forEach((a, key) => {
          const on = key === activeId;
          a.classList.toggle('is-active', on);
          if (on) a.setAttribute('aria-current', 'true');
          else a.removeAttribute('aria-current');
        });
      }

      let spyTicking = false;
      function onSpyScroll() {
        if (spyTicking) return;
        spyTicking = true;
        requestAnimationFrame(() => {
          updateTocSpy();
          spyTicking = false;
        });
      }
      window.addEventListener('scroll', onSpyScroll, { passive: true });
      window.addEventListener('resize', onSpyScroll, { passive: true });

      // Search (Pagefind): the bundle only exists in the BUILT site, so it's
      // injected on demand the first time /search is shown and the UI is mounted
      // on every navigation there (the #search node is fresh after each swap).
      // This is why reaching /search via an in-site link now works — the old
      // DOMContentLoaded init never re-fired after a View Transition.
      let pagefindJs: Promise<boolean> | null = null;
      function loadPagefindJs(): Promise<boolean> {
        if (pagefindJs) return pagefindJs;
        pagefindJs = new Promise((resolve) => {
          if ((window as any).PagefindUI) return resolve(true);
          const s = document.createElement('script');
          s.src = '/pagefind/pagefind-ui.js';
          s.onload = () => resolve(true);
          s.onerror = () => resolve(false); // dev / no index built yet
          document.head.appendChild(s);
        });
        return pagefindJs;
      }

      function initSearch() {
        const mount = document.getElementById('search');
        if (!mount || mount.dataset.ready) return;
        // Pagefind's stylesheet is dropped from <head> when navigating away;
        // re-add it whenever the search page is shown.
        if (!document.querySelector('link[data-pagefind-css]')) {
          const css = document.createElement('link');
          css.rel = 'stylesheet';
          css.href = '/pagefind/pagefind-ui.css';
          css.setAttribute('data-pagefind-css', '');
          document.head.appendChild(css);
        }
        loadPagefindJs().then((ok) => {
          if (mount.dataset.ready) return;
          const UI = (window as any).PagefindUI;
          if (!ok || typeof UI === 'undefined') {
            mount.innerHTML =
              '<p class="search-missing annotation">Search runs on the built site. Locally, run <code>npm run build</code> then <code>npm run preview</code>.</p>';
            return;
          }
          mount.dataset.ready = '1';
          new UI({ element: '#search', showSubResults: true, showImages: false, resetStyles: false });
        });
      }

      // When a series index is capped and scrolls inside itself (a long series on
      // a stacked layout), bring the current part into view within its own box so
      // the reader lands in place rather than at the top of a scrolled list. Only
      // touches lists that actually overflow, and only their own scrollTop — never
      // the page.
      function alignSeriesCurrent() {
        for (const list of document.querySelectorAll<HTMLElement>('.series__list')) {
          if (list.scrollHeight <= list.clientHeight + 4) continue;
          const cur = list.querySelector<HTMLElement>('.series__item--current');
          if (!cur) continue;
          const offset =
            cur.getBoundingClientRect().top - list.getBoundingClientRect().top + list.scrollTop;
          list.scrollTop = offset - list.clientHeight / 2 + cur.offsetHeight / 2;
        }
      }

      // Lightbox: click a content image to see it enlarged over a dark scrim.
      // Decorative masthead/project art lives outside .prose (untouched); linked
      // images keep their link. Delegated to document, so it needs no per-image
      // wiring and survives View Transitions — the overlay node itself is
      // re-attached on page-load since a swap discards body children.
      let lbOpener: HTMLElement | null = null;

      function ensureLightbox() {
        let overlay = document.getElementById('lightbox');
        if (overlay) return overlay;
        overlay = document.createElement('div');
        overlay.id = 'lightbox';
        overlay.className = 'lightbox';
        overlay.setAttribute('role', 'dialog');
        overlay.setAttribute('aria-modal', 'true');
        overlay.innerHTML =
          '<img class="lightbox__img" alt="" />' +
          '<button type="button" class="lightbox__close" aria-label="Close image">' +
          '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>' +
          '</button>';
        overlay.addEventListener('click', closeLightbox);
        document.body.appendChild(overlay);
        return overlay;
      }

      function openLightbox(img: HTMLImageElement) {
        const overlay = ensureLightbox();
        const big = overlay.querySelector('img') as HTMLImageElement;
        big.src = img.currentSrc || img.src;
        big.alt = img.alt || '';
        lbOpener = img;
        requestAnimationFrame(() => overlay.classList.add('is-open'));
        document.documentElement.classList.add('lightbox-open');
        (overlay.querySelector('.lightbox__close') as HTMLElement | null)?.focus();
      }

      function closeLightbox() {
        const overlay = document.getElementById('lightbox');
        document.documentElement.classList.remove('lightbox-open');
        if (overlay) overlay.classList.remove('is-open');
        lbOpener?.focus?.();
        lbOpener = null;
      }

      // Open on a plain content image; skip linked images (follow the link) and
      // the overlay's own image.
      document.addEventListener('click', (e) => {
        const t = e.target;
        if (!(t instanceof HTMLImageElement)) return;
        if (t.closest('.lightbox') || t.closest('a') || !t.closest('.prose')) return;
        openLightbox(t);
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeLightbox();
        // "/" anywhere (outside a field) jumps into the search box.
        if (e.key === '/' && !e.metaKey && !e.ctrlKey && !e.altKey) {
          const t = e.target as HTMLElement | null;
          const tag = t?.tagName ?? '';
          if (/^(INPUT|TEXTAREA|SELECT)$/.test(tag) || t?.isContentEditable) return;
          const input = document.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
          if (input) {
            e.preventDefault();
            input.focus();
          }
        }
      });

      // Re-apply the saved theme pre-paint on every transition (no flash).
      document.addEventListener('astro:after-swap', applyTheme);

      // Fires on the initial load AND after every client-side navigation.
      document.addEventListener('astro:page-load', () => {
        syncToggle();
        initCopyButtons();
        initMediaSkeletons();
        ensureLightbox();
        // A navigation while the lightbox was open discards the overlay; make
        // sure the scroll lock never survives into the next page.
        document.documentElement.classList.remove('lightbox-open');
        syncRail();
        initTocSpy();
        initSearch();
        alignSeriesCurrent();
      });
    </script>
  </body>
</html>
