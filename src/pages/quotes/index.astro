---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import StreamList from '../../components/StreamList.astro';
import { getQuotes } from '../../lib/content';
import { SITE_TITLE } from '../../consts';

// Quotations: lines worth keeping, with attribution.
const items = await getQuotes();

const heading = [
  { text: 'Lines', size: 'l', weight: 380, italic: true, rot: -2 },
  { text: 'worth keeping', size: 'xl', weight: 640, shift: '2rem', rot: 1, lift: '-2.2rem' },
] as const;
---

<Base
  title={`Quotes — ${SITE_TITLE}`}
  description="Quotations worth keeping, with attribution."
>
  <PageHeader eyebrow="Commonplace book" lines={heading}>
    <p class="masthead__deck">
      A commonplace book — lines worth keeping.
      <a href="/quotes/rss.xml">Quotes feed &rarr;</a>
    </p>
  </PageHeader>

  {items.length === 0 ? <p>Nothing here yet.</p> : <StreamList items={items} />}
</Base>
