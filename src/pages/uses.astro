---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';

// A /uses page (uses.tech convention): the tools I actually reach for. Expanded
// from the About page's "Tools" note into its own reference.
const heading = [
  { text: 'What I', size: 'l', weight: 600, rot: -1.5 },
  { text: 'use', size: 'xl', weight: 720, italic: true, shift: '4.5rem', rot: 1.5, lift: '-1.8rem' },
] as const;
---

<Base title="Uses" description="The languages, ML stack, and tools Shreyash Rai reaches for.">
  <PageHeader eyebrow="The toolbox" lines={heading}>
    <p class="masthead__deck">The languages, libraries, and tools I reach for.</p>
  </PageHeader>

  <div class="prose" data-pagefind-body>
    <h2>Languages</h2>
    <p>Python for almost everything, C++ and C when speed matters, SQL for data.</p>

    <h2>Machine learning</h2>
    <p>
      PyTorch, Stable-Baselines3, and Gymnasium for reinforcement learning;
      Transformers and sentence-transformers for NLP and RAG; scikit-learn,
      NumPy, and Pandas for the classic stack.
    </p>

    <h2>Scientific computing</h2>
    <p>
      Numba for JIT-compiled physics cores, and numerical methods (RK4, DMD,
      FDTD) when a problem calls for them.
    </p>

    <h2>Visualization &amp; tooling</h2>
    <p>
      Matplotlib for plots, Three.js / WebGL for interactive views, Git for
      version control, and this Astro site for writing it all down.
    </p>
  </div>
</Base>
