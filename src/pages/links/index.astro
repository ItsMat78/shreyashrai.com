---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import StreamList from '../../components/StreamList.astro';
import YearNav from '../../components/YearNav.astro';
import { getLinks, groupByYear } from '../../lib/content';

const items = await getLinks();
const groups = groupByYear(items);
const years = groups.map((g) => g.year);

const heading = [
  { text: 'Worth', size: 'l', weight: 600, rot: -1.5 },
  { text: 'a look', size: 'xl', weight: 700, italic: true, shift: '3.5rem', rot: 1.5, lift: '-1.8rem' },
] as const;
---

<Base
  title="Links"
  description="A link blog — things I found worth pointing at, with a line on why."
>
  <PageHeader eyebrow="The link blog" lines={heading}>
    <p class="masthead__deck">
      Things elsewhere worth your time, with a line on why.
      <a href="/links/rss.xml">Links feed &rarr;</a>
    </p>
  </PageHeader>

  <div class="index-grid">
    <div class="index-content">
      {
        years.length === 0 ? (
          <p>Nothing here yet.</p>
        ) : (
          groups.map(({ year, items }) => (
            <section class="year-group" id={`y${year}`}>
              <h2 class="display display--section year-heading">{year}</h2>
              <StreamList items={items} />
            </section>
          ))
        )
      }
    </div>
    <YearNav years={years} />
  </div>
</Base>
