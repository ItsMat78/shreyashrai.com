---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import EntryList from '../components/EntryList.astro';
import Newsletter from '../components/Newsletter.astro';
import { getTils, getPosts, getFeatured } from '../lib/content';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const [tils, posts] = await Promise.all([getTils(), getPosts()]);
const latest = [...tils, ...posts]
  .sort((a, b) => b.date.getTime() - a.date.getTime() || a.id.localeCompare(b.id))
  .slice(0, 6);

const featured = await getFeatured();

// The home thesis: two breaths, roman then italic — learning in public.
const hero = [
  { text: 'Learning', size: 'xl', weight: 680, rot: -1.5 },
  { text: 'out loud.', size: 'xl', weight: 400, italic: true, shift: '5.8rem', rot: 1, lift:'-1.5rem' },
] as const;
---

<Base title={SITE_TITLE} description={SITE_DESCRIPTION} type="website">
  <div class="stack">
    <PageHeader eyebrow="The running notebook for" lines={hero} frames={false}>
      <p class="masthead__deck">
        I'm a Data Science &amp; AI undergrad at IIIT Naya Raipur. This is where I
        keep a running log of things I learn (<a href="/notes">notes</a>) and document the <a href="/projects">projects</a> I build.
      </p>
    </PageHeader>

    <div class="home-grid">
      <section>
        <div class="section-head">
          <h2 class="display display--section">Latest</h2>
          <a class="annotation link-quiet" href="/notes">all notes &rarr;</a>
        </div>
        <EntryList items={latest} showKind showDescription />
        <p class="annotation home-split__rss">
          <a class="link-quiet" href="/rss.xml">Follow along via RSS &rarr;</a>
        </p>
      </section>

      <section>
        <div class="section-head">
          <h2 class="display display--section">Featured</h2>
        </div>
        {
          featured.length > 0 ? (
            <EntryList items={featured} showKind showDescription />
          ) : (
            <p class="annotation">No featured entries yet.</p>
          )
        }
      </section>
    </div>

    <Newsletter />
  </div>
</Base>
