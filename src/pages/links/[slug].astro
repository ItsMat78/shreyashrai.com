---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import FrameField from '../../components/FrameField.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import TagList from '../../components/TagList.astro';
import Backlinks from '../../components/Backlinks.astro';
import Comments from '../../components/Comments.astro';
import { getLinkEntries, getBacklinks, normalizeTags } from '../../lib/content';

export async function getStaticPaths() {
  const entries = await getLinkEntries();
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const tags = normalizeTags(entry.data.tags);
const backlinks = await getBacklinks(entry.id);
---

<Base
  title={entry.data.title}
  description={entry.data.title}
  type="article"
  ogImage={`/og/links/${entry.id}.png`}
>
  <article>
    <header class="article__header">
      <FrameField />
      <p class="eyebrow">The link blog</p>
      <h1 class="display display--title">{entry.data.title}</h1>
      <div class="article__meta">
        <FormattedDate date={entry.data.date} format="long" />
        {entry.data.via && (
          <span class="annotation">
            via{' '}
            {entry.data.viaUrl ? <a href={entry.data.viaUrl}>{entry.data.via}</a> : entry.data.via}
          </span>
        )}
        <TagList tags={tags} />
      </div>
    </header>
    <div class="prose" data-pagefind-body>
      <a class="link-visit" href={entry.data.url}>
        <svg viewBox="0 0 12 12" width="0.9em" height="0.9em" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 10 10 2M4 2h6v6"/></svg>
        Visit site
      </a>
      <Content />
    </div>
    <p class="article__end" aria-hidden="true">&#10086;</p>
    <div class="article__trail">
      <Backlinks links={backlinks} />
    </div>
    <nav class="article-nav" aria-label="More links">
      <a class="article-nav__back" href="/links">&larr; All Links</a>
    </nav>
    <Comments />
  </article>
</Base>
