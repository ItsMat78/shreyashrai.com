---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import StreamList from '../../components/StreamList.astro';
import YearNav from '../../components/YearNav.astro';
import { getQuotes, groupByYear } from '../../lib/content';

const items = await getQuotes();
const groups = groupByYear(items);
const years = groups.map((g) => g.year);

const heading = [
  { text: 'Lines', size: 'l', weight: 380, italic: true, rot: -2 },
  { text: 'worth keeping', size: 'xl', weight: 640, shift: '2rem', rot: 1, lift: '-2.2rem' },
] as const;
---

<Base
  title="Quotes"
  description="Quotations worth keeping, with attribution."
>
  <PageHeader eyebrow="Commonplace book" lines={heading}>
    <p class="masthead__deck">
      A commonplace book — lines worth keeping.
      <a href="/quotes/rss.xml">Quotes feed &rarr;</a>
    </p>
  </PageHeader>

  <div class="index-grid">
    <div class="index-content">
      {
        years.length === 0 ? (
          <p>Nothing here yet.</p>
        ) : (
          groups.map(({ year, items }) => (
            <section class="year-group" id={`y${year}`}>
              <h2 class="display display--section year-heading">{year}</h2>
              <StreamList items={items} />
            </section>
          ))
        )
      }
    </div>
    <YearNav years={years} />
  </div>
</Base>
