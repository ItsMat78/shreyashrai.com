---
import { GITHUB_URL, EMAIL } from '../consts';
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <nav class="site-footer__links annotation" aria-label="Footer">
      <a class="link-quiet" href="/now">Now</a>
      <a class="link-quiet" href="/uses">What I use</a>
      <a class="link-quiet" href="/series">Series</a>
      <a class="link-quiet" href={GITHUB_URL} rel="me">GitHub</a>
      <a class="link-quiet" href={`mailto:${EMAIL}`}>Email</a>
      <a class="link-quiet" href="/rss.xml">RSS</a>
      {/* Back to top — target=_self so the page's <base target=_blank> doesn't
          open it in a new tab; #top scrolls to the document top (glides via
          scroll-behavior: smooth). */}
      <a class="link-quiet site-footer__top" href="#top" target="_self">Top &uarr;</a>
    </nav>
    <p class="site-footer__colophon annotation">
      <span class="site-footer__fleuron" aria-hidden="true">&#10086;</span>
      Fonts: <span class="display">Fraunces</span> &amp; Schibsted Grotesk
    </p>
  </div>
</footer>
