---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import EntryList from '../../components/EntryList.astro';
import type { EntryItem } from '../../lib/content';
import { getAllTags, getEntriesByTag } from '../../lib/content';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
  const tags = await getAllTags();
  const paths = [];
  for (const { tag } of tags) {
    paths.push({
      params: { tag },
      props: { tag, items: await getEntriesByTag(tag) },
    });
  }
  return paths;
}

interface Props {
  tag: string;
  items: EntryItem[];
}

const { tag, items } = Astro.props;
const count = items.length;

const heading = [
  { text: 'On', size: 'm', weight: 380, italic: true },
  { text: tag, size: 'xl', weight: 660, shift: '2.5rem', rot: -1.5, lift:'-2.5rem' },
] as const;
---

<Base
  title={`#${tag} — ${SITE_TITLE}`}
  description={`All TILs and posts tagged “${tag}”.`}
>
  <PageHeader eyebrow="Tagged" lines={heading}>
    <p class="masthead__deck">
      {count} {count === 1 ? 'entry' : 'entries'} tagged &ldquo;{tag}&rdquo;.
      <a href="/tags">All tags &rarr;</a>
      <br>
      <a href={`/tags/${tag}/rss.xml`}>Feed for this tag &rarr;</a>
    </p>
  </PageHeader>

  <EntryList items={items} showKind showDescription />
</Base>
