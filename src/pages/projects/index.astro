---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getProjectEntries } from '../../lib/content';

// Hand-ordered, draft-filtered — through the single content layer so the draft
// filter is never re-implemented (same guarantee as til/blog).
const projects = await getProjectEntries();

const heading = [
  { text: 'Things', size: 'xl', weight: 620, rot: -2 },
  { text: "I've", size: 'm', weight: 380, italic: true, shift: '9rem' },
  { text: 'built', size: 'xl', weight: 720, shift: '7rem', rot: 1.5, lift: '-2.1rem' },
] as const;
---

<Base
  title="Projects"
  description="Things I've built. Simulations, research and small tools."
>
  <PageHeader eyebrow="Selected work" lines={heading}>
    <p class="masthead__deck">
      Things I've built. Simulations, research and small tools with links where they're live or open source.
    </p>
  </PageHeader>

  <ul class="project-list">
    {
      projects.map((project, i) => (
        <li class="project">
          <div
            class="project__cover"
            data-has-cover={project.data.cover ? 'true' : 'false'}
            data-index={String(i + 1).padStart(2, '0')}
            style={project.data.cover ? `background-image:url(${project.data.cover})` : undefined}
            aria-hidden="true"
          />
          {project.data.headerArt && (
            <img class="project-art" src={project.data.headerArt} alt="" decoding="async" />
          )}
          <div class="project__lead">
            <span class="project__index tabular" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <h2 class="project__title">
              {/* Stretched link: the whole row opens the writeup. */}
              <a class="project__link" href={`/projects/${project.id}/`}>
                {project.data.title}
              </a>
            </h2>
          </div>
          <div class="project__body">
            {project.data.outcome && (
              <p class="project__outcome">{project.data.outcome}</p>
            )}
            <p class="project__blurb" set:html={project.data.blurb} />
            {project.data.tech.length > 0 && (
              <ul class="project__tech" aria-label="Tech stack">
                {project.data.tech.map((t) => (
                  <li>{t}</li>
                ))}
              </ul>
            )}
            <div class="project__links annotation">
              <a class="link-quiet" href={`/projects/${project.id}/`}>
                Writeup <span class="project__arrow"><svg viewBox="0 0 12 12" width="0.8em" height="0.8em" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 10 10 2M4 2h6v6"/></svg></span>
              </a>
              {project.data.live && (
                <a class="link-quiet" href={project.data.live}>
                  Deployment <span class="project__arrow"><svg viewBox="0 0 12 12" width="0.8em" height="0.8em" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 10 10 2M4 2h6v6"/></svg></span>
                </a>
              )}
              {project.data.source && (
                <a class="link-quiet" href={project.data.source}>
                  Repository <span class="project__arrow"><svg viewBox="0 0 12 12" width="0.8em" height="0.8em" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 10 10 2M4 2h6v6"/></svg></span>
                </a>
              )}
            </div>
          </div>
        </li>
      ))
    }
  </ul>
</Base>
