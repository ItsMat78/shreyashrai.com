---
import { SITE_TITLE, SITE_DESCRIPTION, CF_ANALYTICS_TOKEN } from '../consts';

interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  ogImage?: string;
}

const {
  title,
  description = SITE_DESCRIPTION,
  type = 'website',
  ogImage = '/og/default.png',
} = Astro.props;

// Canonical URL: absolute, without a trailing slash (except the root).
const path = Astro.url.pathname.replace(/\/+$/, '');
const canonical = new URL(path || '/', Astro.site).href;
// Share card must be an absolute URL for crawlers.
const ogImageUrl = new URL(ogImage, Astro.site).href;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!--
  Set the theme before first paint so there's no flash: an explicit choice in
  localStorage wins; otherwise follow the system preference. Everything else in
  the CSS keys off this [data-theme] attribute.
-->
<script is:inline>
  (function () {
    try {
      var stored = localStorage.getItem('theme');
      var theme =
        stored === 'light' || stored === 'dark'
          ? stored
          : window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light';
      document.documentElement.dataset.theme = theme;
    } catch (e) {}
  })();
</script>

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

<!-- Icons -->
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />

<!-- Preload the two self-hosted fonts to avoid a flash / layout shift -->
<link
  rel="preload"
  href="/fonts/schibsted-grotesk-latin.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/fraunces-latin.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/fraunces-italic-latin.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>

<!-- Feed autodiscovery -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${SITE_TITLE} — all`}
  href="/rss.xml"
/>
<link
  rel="alternate"
  type="application/feed+json"
  title={`${SITE_TITLE} — all (JSON)`}
  href="/feed.json"
/>

<!-- Open Graph / Twitter -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={ogImageUrl} />

<!--
  Cloudflare Web Analytics: privacy-first (no cookies, no fingerprinting),
  free with Cloudflare Pages. Ships only when a token is set in consts.ts.
  Note: feed readers hitting rss.xml never run JS — those show up in the
  Cloudflare dashboard's server-side traffic view instead.
-->
{
  CF_ANALYTICS_TOKEN && (
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon={JSON.stringify({ token: CF_ANALYTICS_TOKEN })}
    />
  )
}
